# Copy this file to ".env" and fill in your own values.

# A random long string used to sign login sessions. Change this to anything unique.
SESSION_SECRET=change-this-to-a-random-string

# Port the server runs on (most hosting providers set this automatically)
PORT=3000

# --- Email (SMTP) settings ---
# Required only for the "Send to Customer by Email" button in the Head portal.
# Example using Gmail: create an "App Password" in your Google Account security
# settings (regular Gmail passwords will not work).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="AEC Sdn Bhd <your-email@gmail.com>"
